    <script nonce="a7hv2amJux0EFBpLVrfwnhKWFNPuYHLh">
        $(document).ready(function() {
            $(".card").hover(
                function() {
                    $(this).addClass('shadow-lg').css('cursor', 'pointer');
                },
                function() {
                    $(this).removeClass('shadow-lg');
                }
            );

            // Filter and Sort Functionality
            function initFiltersAndSort() {
                const $searchCourses = $('#searchCourses');
                const $sortBy = $('#sortBy');
                const $resetFilters = $('#resetFilters');
                const $coursesGrid = $('#coursesGrid');
                const $resultsCount = $('#resultsCount');

                if ($searchCourses.length === 0 || $sortBy.length === 0 || $resetFilters.length === 0 || $coursesGrid.length === 0 || $resultsCount.length === 0) {
                    return;
                }

                const $allCourses = $('.course-item');
                const totalCourses = $allCourses.length;

                if (totalCourses === 0) {
                    return;
                }

                function applyFiltersAndSort() {
                    // Get selected filter and sort values
                    const searchText = $searchCourses.val().toLowerCase().trim();
                    const sortValue = $sortBy.val();

                    // Filter courses by search text
                    let $filteredCourses = $allCourses.filter(function() {
                        if (searchText === '') {
                            return true;
                        }
                        // Read data attributes
                        const courseElement = this;
                        const courseName = courseElement.getAttribute('data-name') || '';
                        const courseDescription = courseElement.getAttribute('data-description') || '';

                        // Search in both name and description
                        return courseName.includes(searchText) || courseDescription.includes(searchText);
                    });

                    // Convert to array for sorting
                    let filteredArray = $filteredCourses.toArray();

                    // Sort courses
                    filteredArray.sort(function(a, b) {
                        const $a = $(a);
                        const $b = $(b);

                        switch(sortValue) {
                            case 'recommended':
                                // First, course with id = 125 comes first
                                const aId = parseInt($a.attr('data-id'));
                                const bId = parseInt($b.attr('data-id'));
                                if (aId === 125 && bId !== 125) {
                                    return -1;
                                }
                                if (aId !== 125 && bId === 125) {
                                    return 1;
                                }
                                // Then sort by priority_order descending
                                const aPriority = parseInt($a.attr('data-priority-order')) || 0;
                                const bPriority = parseInt($b.attr('data-priority-order')) || 0;
                                if (bPriority !== aPriority) {
                                    return bPriority - aPriority;
                                }
                                // If priority_order is the same, maintain original order
                                return 0;
                            case 'name':
                                return $a.attr('data-name').localeCompare($b.attr('data-name'));
                            case 'price-low':
                                return parseFloat($a.attr('data-price')) - parseFloat($b.attr('data-price'));
                            case 'price-high':
                                return parseFloat($b.attr('data-price')) - parseFloat($a.attr('data-price'));
                            case 'level':
                                const levelOrder = { 'beginner': 1, 'intermediate': 2, 'advanced': 3 };
                                const aLevel = $a.attr('data-level');
                                const bLevel = $b.attr('data-level');
                                return levelOrder[aLevel] - levelOrder[bLevel];
                            default:
                                return 0;
                        }
                    });

                    // First, hide all courses
                    $allCourses.addClass('course-item-hidden');

                    // Create a set of filtered course elements for quick lookup
                    const filteredSet = new Set(filteredArray);

                    // Show and append filtered courses in sorted order
                    filteredArray.forEach(function(course) {
                        const $course = $(course);
                        $course.detach();
                        $course.removeClass('course-item-hidden');
                        $coursesGrid.append($course);
                    });

                    // Ensure all non-filtered courses remain hidden
                    $allCourses.not(filteredArray).addClass('course-item-hidden');

                    // Update results count
                    if (filteredArray.length === 0) {
                        $resultsCount.text('No courses found matching your criteria');
                    } else {
                        $resultsCount.text('Showing ' + filteredArray.length + ' of ' + totalCourses + ' courses');
                    }
                }

                // Event listeners using jQuery
                $searchCourses.on('input', applyFiltersAndSort);
                $sortBy.on('change', applyFiltersAndSort);

                $resetFilters.on('click', function(e) {
                    e.preventDefault();
                    $searchCourses.val('');
                    $sortBy.val('recommended');
                    applyFiltersAndSort();
                });

                // Initial application of filters
                applyFiltersAndSort();
            }

            // Initialize after a delay to ensure Vue has rendered
            setTimeout(initFiltersAndSort, 500);

            // Also try on window load as fallback
            $(window).on('load', function() {
                setTimeout(initFiltersAndSort, 200);
            });
        });
    </script>









































